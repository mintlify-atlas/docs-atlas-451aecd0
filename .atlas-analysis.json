  "keyFeatures": [
    "Real-time messaging with WebSocket support",
    "Self-destructing chat rooms with configurable TTL",
    "Two-participant limit per room",
    "Cookie-based authentication",
    "Upstash Redis for message persistence",
    "Anonymous username generation",
    "Room link sharing",
    "Manual room destruction"
  ],
  "publicApiSurface": [
    "POST /api/room/create - Create a new chat room",
    "GET /api/room/ttl - Get room time-to-live",
    "DELETE /api/room - Destroy a room",
    "POST /api/messages - Send a message",
    "GET /api/messages - Retrieve room messages",
    "WebSocket Events: chat.message, chat.destroy",
    "RealtimeClient: useRealtime hook",
    "Authentication: Cookie-based token system"
